    "android": "powershell -ExecutionPolicy Bypass -Command \". ./scripts/ensure-node.ps1; npx expo start --android\"",
    "ios": "powershell -ExecutionPolicy Bypass -Command \". ./scripts/ensure-node.ps1; npx expo start --ios\"",
    "web": "powershell -ExecutionPolicy Bypass -Command \". ./scripts/ensure-node.ps1; npx expo start --web\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit"
  },
  "private": true,
  "engines": {
    "node": ">=20.19.4"
